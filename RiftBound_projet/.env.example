# Riot Developer Portal — clé d'API (ingestion cards uniquement)
RIOT_API_KEY=

# Région Riot pour le content endpoint (americas | europe | asia | sea)
RIOT_API_REGION=americas

# Locale des cartes (beta: en uniquement)
RIOT_LOCALE=en_US

# Serveur
PORT=3001
REDIS_URL=redis://127.0.0.1:6379
CLIENT_ORIGIN=http://localhost:5173
